<UserControl x:Class="MachineControlBase.SequenceNoViewUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="30" d:DesignWidth="420" Background="#FF222222"
             mc:Ignorable="d">
    <Grid Margin="5">
        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
            <TextBlock x:Name="TbName" Width="300" FontSize="12" Foreground="WhiteSmoke" Text="Name" />
            <TextBlock x:Name="TbStepNo" Width="50" FontSize="12" Foreground="WhiteSmoke" Text="No" />
            <TextBlock x:Name="TbSubStepNo" Width="50" Margin="0,0,10,0" FontSize="12" Foreground="WhiteSmoke" Text="SNo" />
        </StackPanel>
    </Grid>
</UserControl>