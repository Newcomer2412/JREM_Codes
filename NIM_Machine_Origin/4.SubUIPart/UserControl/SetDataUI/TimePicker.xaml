<UserControl x:Class="MachineControlBase.TimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="35" d:DesignWidth="150"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="0.3*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="0.3*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.7*" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="txtHours"
                 Height="31"
                 HorizontalAlignment="Stretch" VerticalAlignment="Center" VerticalContentAlignment="Center"
                 Background="#3c3c3c" BorderThickness="0" FontSize="19" Foreground="WhiteSmoke" KeyUp="txt_KeyUp" MaxLength="2"
                 MouseWheel="txt_MouseWheel" PreviewKeyUp="txt_PreviewKeyUp" Text="19" TextAlignment="Center" />
        <TextBlock Grid.Column="1"
                   Width="3" Height="15"
                   Margin="0,6,1,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   Foreground="WhiteSmoke" Text=":" TextAlignment="Center" />
        <TextBlock Grid.Column="3"
                   Width="3" Height="15"
                   Margin="0,6,0,8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                   Foreground="WhiteSmoke" Text=":" TextAlignment="Center" />
        <TextBox x:Name="txtMinutes"
                 Grid.Column="2"
                 Height="31"
                 HorizontalAlignment="Stretch" VerticalAlignment="Center" VerticalContentAlignment="Center"
                 Background="#3c3c3c" BorderThickness="0" FontSize="19" Foreground="WhiteSmoke" KeyUp="txt_KeyUp" MaxLength="2"
                 MouseWheel="txt_MouseWheel" PreviewKeyUp="txt_PreviewKeyUp" Text="19" TextAlignment="Center" />
        <TextBox x:Name="txtSeconds"
                 Grid.Column="4"
                 Height="31"
                 HorizontalAlignment="Stretch" VerticalAlignment="Center" VerticalContentAlignment="Center"
                 Background="#3c3c3c" BorderThickness="0" FontSize="19" Foreground="WhiteSmoke" KeyUp="txt_KeyUp" MaxLength="2"
                 MouseWheel="txt_MouseWheel" PreviewKeyUp="txt_PreviewKeyUp" Text="19" TextAlignment="Center" />

        <Grid Grid.Column="7">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border Margin="1" BorderBrush="LightBlue" BorderThickness="0">
                <Button x:Name="btnUp" Grid.Row="0" BorderThickness="0" Click="btnUp_Click" Focusable="False">
                    <Image Source="..\..\..\ImagePart\Up.png" Stretch="Uniform" />
                </Button>
            </Border>

            <Border Grid.Row="1" Margin="1" BorderBrush="LightBlue" BorderThickness="0">
                <Button x:Name="btnDown" Grid.Row="1" BorderThickness="0" Click="btnDown_Click" Focusable="False">
                    <Image Source="..\..\..\ImagePart\Down.png" Stretch="Uniform" />
                </Button>
            </Border>
        </Grid>
    </Grid>
</UserControl>