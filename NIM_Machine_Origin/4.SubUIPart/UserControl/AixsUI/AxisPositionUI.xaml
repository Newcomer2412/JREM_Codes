<UserControl x:Class="MachineControlBase.AxisPositionUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="30" d:DesignWidth="420"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition Width="0.6*" />
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="6" Background="Black" BorderBrush="Black" CornerRadius="10" />
        <Viewbox HorizontalAlignment="Left" Stretch="Uniform">
            <TextBlock x:Name="TBMoveType" Margin="3,3,3,3" FontWeight="Light" Foreground="WhiteSmoke" Text="ABS" />
        </Viewbox>
        <Viewbox Grid.Column="1" HorizontalAlignment="Left" Stretch="Uniform">
            <TextBlock x:Name="TBName" Margin="3,3,3,3" FontWeight="Light" Foreground="WhiteSmoke" MouseLeftButtonUp="TBName_MouseLeftButtonUp" Text="No Name" />
        </Viewbox>
        <Viewbox Grid.Column="2" Stretch="Uniform">
            <TextBlock x:Name="TBPos"
                       Margin="3,3,3,3"
                       Background="#00000000" FontWeight="Light" Foreground="WhiteSmoke" MouseLeftButtonUp="TBPos_MouseDown" Text="9999.999" />
        </Viewbox>
        <Viewbox Grid.Column="3" Stretch="Uniform">
            <TextBlock x:Name="TBUnit" Margin="3,3,3,3" Background="#00000000" FontWeight="Light" Foreground="WhiteSmoke" Text="um" />
        </Viewbox>
        <Viewbox Grid.Column="4" Stretch="Uniform">
            <TextBlock x:Name="TBVel"
                       Margin="3,3,3,3"
                       Background="#00000000" FontWeight="Light" Foreground="WhiteSmoke" MouseLeftButtonUp="TBVel_MouseDown" Text="100" />
        </Viewbox>
    </Grid>
</UserControl>