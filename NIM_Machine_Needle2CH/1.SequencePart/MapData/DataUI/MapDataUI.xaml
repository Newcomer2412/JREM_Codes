<UserControl x:Class="MachineControlBase.MapDataUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="100" d:DesignWidth="300"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Border x:Name="BdNameView" Height="27" Background="#FF333333" CornerRadius="10,10,0,0">
            <Viewbox Margin="5">
                <TextBlock x:Name="TbMapName" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="WhiteSmoke" Text="Name" />
            </Viewbox>
        </Border>
        <Border x:Name="BdDataView" Grid.Row="1" Grid.Column="1" Background="#77222222" CornerRadius="0,0,10,10">
            <Grid x:Name="GdDataView">
                <Canvas x:Name="CanvasView" Visibility="Hidden" />
            </Grid>
        </Border>
        <Popup x:Name="Popup_UnitStatus" AllowsTransparency="True" HorizontalOffset="0" Placement="Bottom" PopupAnimation="Fade" VerticalOffset="0">
            <Grid x:Name="Popup_Grid" Grid.Row="1">
                <Border Grid.RowSpan="20" Grid.ColumnSpan="20" Background="#FF333333" CornerRadius="5,5,5,5" />
            </Grid>
        </Popup>
        <Popup x:Name="Popup_AllUnitStatus"
               Width="1200" Height="120"
               AllowsTransparency="True" HorizontalOffset="0" Placement="Bottom" PopupAnimation="Fade" VerticalOffset="0">
            <Grid x:Name="Popup_AllGrid" Margin="1">
                <Border Grid.RowSpan="20" Grid.ColumnSpan="20" Background="#FF333333" CornerRadius="5,5,5,5" />
            </Grid>
        </Popup>
    </Grid>
</UserControl>