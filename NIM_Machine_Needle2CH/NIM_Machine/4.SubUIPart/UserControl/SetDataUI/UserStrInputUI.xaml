<UserControl x:Class="MachineControlBase.UserStrInputUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="30" d:DesignWidth="370"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="0.4*" />
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="1" Background="#FF666666" BorderThickness="0" CornerRadius="10,0,0,10" />
        <Viewbox Grid.Column="0" Margin="0,0,15,0" HorizontalAlignment="Left" Stretch="Uniform">
            <TextBlock x:Name="TbInputName" Margin="10,0,0,1" FontWeight="Light" Foreground="WhiteSmoke" Text="No Name" />
        </Viewbox>
        <Border Grid.Column="1" Margin="-10,0,0,0" Background="Black" BorderThickness="0" CornerRadius="10,10,10,10" MouseLeftButtonUp="Data_MouseLeftButtonUp" />
        <Viewbox Grid.Column="1" Stretch="Uniform">
            <TextBox x:Name="TbData"
                     Margin="0,0,0,1"
                     Background="Black" BorderThickness="0" Foreground="WhiteSmoke" MouseLeftButtonUp="Data_MouseLeftButtonUp" Text="0" />
        </Viewbox>
    </Grid>
</UserControl>