<Window x:Class="MachineControlBase.NumPadUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Width="300" Height="420"
        AllowsTransparency="True" Background="#FF222222" PreviewKeyDown="Window_PreviewKeyDown" ResizeMode="NoResize" Topmost="True"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*" />
            <RowDefinition Height="1.4*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Grid.ColumnSpan="4" Margin="0,0,0,3" Background="Black" CornerRadius="5,5,5,5" MouseDown="InputData_MouseDown">
            <Viewbox HorizontalAlignment="Center" Stretch="Uniform">
                <TextBlock Margin="0,0,1,0" FontWeight="Bold" Foreground="WhiteSmoke" Text="KeyPad" />
            </Viewbox>
        </Border>
        <Border Grid.Row="1" Grid.ColumnSpan="4" Margin="0,0,0,2" Background="#66555555" CornerRadius="5,5,5,5">
            <Viewbox HorizontalAlignment="Right" Stretch="Uniform">
                <TextBox x:Name="TBInputData" Margin="0,0,1,0" Background="#11555555" BorderThickness="0" Foreground="WhiteSmoke" Text="0.000" />
            </Viewbox>
        </Border>
        <TextBlock x:Name="TBOldInputData"
                   Grid.Row="1" Grid.Column="3"
                   Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Top"
                   Foreground="WhiteSmoke" Text="0.000" />

        <Button Grid.Row="2" Grid.Column="0"
                Background="#11555555" Click="Clear_Click" Content="C" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                Background="#11555555" Click="Delete_Click" FontSize="35" FontWeight="Bold" Foreground="Black">
            <Image MaxHeight="40" Source="..\..\..\ImagePart\delete.png" />
        </Button>
        <Button Grid.Row="2" Grid.Column="3"
                Background="#11555555" Click="Cancel_Click" FontSize="35" FontWeight="Bold" Foreground="Black">
            <Image MaxHeight="40" Source="..\..\..\ImagePart\close.png" />
        </Button>

        <Button Grid.Row="3" Grid.Column="0"
                Background="#CC000000" Click="Num_Click" Content="7" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="3" Grid.Column="1"
                Background="#CC000000" Click="Num_Click" Content="8" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="3" Grid.Column="2"
                Background="#CC000000" Click="Num_Click" Content="9" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="3" Grid.Column="3"
                Background="#11555555" Click="Num_Click" Content="±" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />

        <Button Grid.Row="4" Grid.Column="0"
                Background="#CC000000" Click="Num_Click" Content="4" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="4" Grid.Column="1"
                Background="#CC000000" Click="Num_Click" Content="5" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="4" Grid.Column="2"
                Background="#CC000000" Click="Num_Click" Content="6" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="4" Grid.Column="3"
                Background="#11555555" Click="Num_Click" Content="PSet" FontSize="25" Foreground="WhiteSmoke" />

        <Button Grid.Row="5" Grid.Column="0"
                Background="#CC000000" Click="Num_Click" Content="1" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="5" Grid.Column="1"
                Background="#CC000000" Click="Num_Click" Content="2" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="5" Grid.Column="2"
                Background="#CC000000" Click="Num_Click" Content="3" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button x:Name="BtSet"
                Grid.Row="5" Grid.RowSpan="2" Grid.Column="3"
                Background="#11555555" Click="SetData_Click" FontSize="35" FontWeight="Bold" Foreground="Black">
            <Image MaxHeight="40" Source="..\..\..\ImagePart\enter.png" />
        </Button>

        <Button Grid.Row="6" Grid.ColumnSpan="2"
                Background="#CC000000" Click="Num_Click" Content="0" FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
        <Button Grid.Row="6" Grid.Column="2"
                Background="#CC000000" Click="Num_Click" Content="." FontSize="35" FontWeight="Bold" Foreground="WhiteSmoke" />
    </Grid>
</Window>