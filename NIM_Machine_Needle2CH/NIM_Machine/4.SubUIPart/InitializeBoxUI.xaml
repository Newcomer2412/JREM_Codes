<Window x:Class="MachineControlBase.InitializeBoxUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Width="1920" Height="1080"
        AllowsTransparency="True" Background="#EF222222" Left="0" Loaded="Window_Loaded" ResizeMode="NoResize" Top="0"
        Topmost="False" WindowStartupLocation="CenterScreen" WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <local:CircularProgressBar x:Name="ProgressBar" Width="400" Height="400" Margin="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock x:Name="TBProgesssText" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="90" Foreground="WhiteSmoke" Text="0%" />
        <TextBlock x:Name="TBProgressName"
                   Margin="0,-650,0,0" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="80" Foreground="WhiteSmoke" Text="Homming..." />
        <Button x:Name="BTHomeStartStop"
                Width="300" Height="120"
                Margin="0,650,0,0"
                Background="Black" BorderBrush="WhiteSmoke" Click="BtHomeStartStop_Click" Content="START" FontSize="70" FontWeight="Bold"
                Foreground="WhiteSmoke" />
    </Grid>
</Window>