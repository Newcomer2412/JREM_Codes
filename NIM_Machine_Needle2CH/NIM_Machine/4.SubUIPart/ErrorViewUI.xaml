<UserControl x:Class="MachineControlBase.ErrorViewUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DesignHeight="1080" d:DesignWidth="1800" IsVisibleChanged="UserControl_IsVisibleChanged"
             mc:Ignorable="d">
    <!--  Main UI 가로 7등분 분할  -->
    <Grid x:Name="Main" Margin="10" Background="#FF151515">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.06*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.3*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.7*" />
            </Grid.ColumnDefinitions>

            <Border Margin="2,2,0,2" Background="#3c3c3c" CornerRadius="5,0,0,5">
                <Viewbox Margin="2" HorizontalAlignment="Stretch">
                    <DatePicker HorizontalAlignment="Center" VerticalAlignment="Top"
                                Background="#3c3c3c" BorderBrush="#3c3c3c" BorderThickness="0" Foreground="White"
                                SelectedDate="{x:Static sys:DateTime.Now}"
                                SelectedDateChanged="DpStart_SelectedDateChanged">

                        <DatePicker.Resources>
                            <Style TargetType="{x:Type DatePickerTextBox}">
                                <Setter Property="Background" Value="#3c3c3c" />
                                <Setter Property="BorderBrush" Value="#3c3c3c" />
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                </Viewbox>
            </Border>

            <Border Grid.Column="1" Margin="0,2,0,2" Background="#3c3c3c">
                <Viewbox HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <local:TimePicker x:Name="St_date" Grid.Row="1" Grid.Column="0" Width="200" Height="40" />
                </Viewbox>
            </Border>

            <Border Grid.Column="2" Margin="0,2,0,2" Background="#3c3c3c" />
            <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Text="To" />

            <Border Grid.Column="3" Margin="0,2,0,2" Background="#3c3c3c">
                <Viewbox Margin="2" HorizontalAlignment="Stretch">
                    <DatePicker HorizontalAlignment="Center" VerticalAlignment="Top"
                                Background="#3c3c3c" BorderBrush="#3c3c3c" BorderThickness="0" Foreground="White"
                                SelectedDate="{x:Static sys:DateTime.Now}"
                                SelectedDateChanged="DpEnd_SelectedDateChanged">

                        <DatePicker.Resources>
                            <Style TargetType="{x:Type DatePickerTextBox}">
                                <Setter Property="Background" Value="#3c3c3c" />
                                <Setter Property="BorderBrush" Value="#3c3c3c" />
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                </Viewbox>
            </Border>

            <Border Grid.Column="4" Margin="0,2,0,2" Background="#3c3c3c" CornerRadius="0,5,5,0">
                <Viewbox HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <local:TimePicker x:Name="Ed_date" Grid.Row="1" Grid.Column="2" Width="200" Height="40" />
                </Viewbox>
            </Border>

            <Button x:Name="BtSearch"
                    Grid.Column="5"
                    Background="#FFE68852" Click="YSrch_btn_Click" Content="Search" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid x:Name="GdVisionMain" Background="#FF151515">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.7*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <!--  chart 표시 화면  -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>

                        <Border Background="#FF333333" CornerRadius="15,15,15,15">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Heavy" Foreground="AntiqueWhite" Text="Searched Result" />
                        </Border>

                        <Border Grid.Row="1" CornerRadius="0,0,10,10">
                            <TabControl>
                                <TabControl.Resources>
                                    <Style TargetType="TabItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TabItem">
                                                    <Grid Name="Header">
                                                        <ContentPresenter x:Name="ContentSite" Margin="10,2" HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Header" Property="Background" Value="#0c4da2" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="False">
                                                            <Setter TargetName="Header" Property="Background" Value="Transparent" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TabControl.Resources>

                                <TabItem x:Name="tbFEo" Background="Transparent" Foreground="AntiqueWhite" Header="Frequency of Error occurrence">
                                    <ListView x:Name="LvResult" Grid.Row="1" Background="Black" BorderThickness="0" Foreground="AntiqueWhite">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListViewItem}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Background" Value="Black" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="true">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Background" Value="Black" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridView.ColumnHeaderContainerStyle>
                                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                                        <!--  Set any properties you want to set  -->
                                                        <Setter Property="Background" Value="Black" />
                                                        <Setter Property="Foreground" Value="WhiteSmoke" />
                                                    </Style>
                                                </GridView.ColumnHeaderContainerStyle>
                                                <GridViewColumn Width="45" DisplayMemberBinding="{Binding Count}" Header="Count" />
                                                <GridViewColumn Width="65" DisplayMemberBinding="{Binding ErrorCode}" Header="Error Code" />
                                                <GridViewColumn Width="350" DisplayMemberBinding="{Binding ErrorName}" Header="Error Name" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </TabItem>

                                <TabItem x:Name="tbEOL" HorizontalContentAlignment="Stretch" Background="Transparent" Foreground="AntiqueWhite" Header="Error Occurrence List">
                                    <ListView x:Name="lvAllerror" Grid.Row="1" Background="Black" BorderThickness="0" Foreground="AntiqueWhite">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListViewItem}">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Background" Value="Black" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="true">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Background" Value="Black" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.View>
                                            <GridView>
                                                <GridView.ColumnHeaderContainerStyle>
                                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                                        <!--  Set any properties you want to set  -->
                                                        <Setter Property="Background" Value="Black" />
                                                        <Setter Property="Foreground" Value="WhiteSmoke" />
                                                    </Style>
                                                </GridView.ColumnHeaderContainerStyle>
                                                <GridViewColumn Width="150" DisplayMemberBinding="{Binding Time}" Header="Error Occurred Time" />
                                                <GridViewColumn Width="65" DisplayMemberBinding="{Binding ErrorCode}" Header="Error Code" />
                                                <GridViewColumn Width="350" DisplayMemberBinding="{Binding ErrorName}" Header="Error Name" />
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>

                    <Border Background="#FF333333" CornerRadius="15,15,15,15">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Heavy" Foreground="AntiqueWhite" Text="Searched Result in Bar Chart" />
                    </Border>
                    <ContentControl x:Name="GdMainView" Grid.Row="1" BorderThickness="0">
                        <local:Column x:Name="Column" />
                    </ContentControl>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>