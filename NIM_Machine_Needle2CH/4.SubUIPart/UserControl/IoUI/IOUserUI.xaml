<UserControl x:Class="MachineControlBase.IOUserUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="20" d:DesignWidth="200"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.15*" />
            <ColumnDefinition Width="0.17*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Border x:Name="IOTypeBackground"
                Grid.Column="0" Grid.ColumnSpan="2"
                Background="CadetBlue" BorderBrush="Black" BorderThickness="0" CornerRadius="5,0,0,5" />
        <Border x:Name="IOOnOffBackground" Grid.Column="2" Background="Black" BorderBrush="Black" BorderThickness="0" CornerRadius="0,5,5,0" />

        <Viewbox Grid.Column="0" Stretch="Uniform">
            <TextBlock x:Name="IOType" Margin="0,0,0,1" FontWeight="Bold" Foreground="WhiteSmoke" Text="I" />
        </Viewbox>
        <Viewbox Grid.Column="1" Stretch="Uniform">
            <TextBlock x:Name="IOAddress" Margin="0,0,0,1" FontWeight="Bold" Foreground="Black" Text="1A" />
        </Viewbox>
        <Button x:Name="BTSet" Grid.Column="2" Background="#00000000" Click="BTSet_Click">
            <Viewbox Stretch="Uniform">
                <TextBlock x:Name="IOName" Margin="0,0,0,1" FontWeight="Light" Foreground="WhiteSmoke" Text="NONAME" />
            </Viewbox>
        </Button>
    </Grid>
</UserControl>