<Window x:Class="MachineControlBase.ManualMotionUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="MotionUI"
        Width="950" Height="650"
        AllowsTransparency="True" Background="#FF222222" ResizeMode="NoResize" Topmost="True" WindowStartupLocation="CenterScreen" WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid Width="335" Margin="7" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.2*" />
                <RowDefinition Height="0.4*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="0.4*" />
                <RowDefinition Height="0.3*" />
            </Grid.RowDefinitions>

            <Border Margin="0,0,0,4" Background="AntiqueWhite" CornerRadius="5,5,5,5" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="17" FontWeight="Bold" Text="Motion UI" />
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.4*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="41*" />
                    <ColumnDefinition Width="149*" />
                    <ColumnDefinition Width="48*" />
                    <ColumnDefinition Width="48*" />
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="4" Background="CadetBlue" CornerRadius="10,10,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="WhiteSmoke" Text="Axis Selection" />
                </Border>
                <Border Grid.Row="1" Grid.ColumnSpan="4" Background="#FF333333" CornerRadius="0,0,10,10" />
                <ComboBox Name="CbAxisList" Grid.Row="1" Grid.ColumnSpan="2" Margin="5,10,1,10" SelectionChanged="CbAxisList_SelectionChanged" />
                <Button Grid.Row="1" Grid.Column="2"
                        Margin="5,10,0,10"
                        Background="PaleVioletRed" Click="SON_Button_Click" Content="ON" FontWeight="Bold" Foreground="WhiteSmoke" />
                <Button Grid.Row="1" Grid.Column="3"
                        Margin="0,10,5,10"
                        Background="DodgerBlue" Click="SOFF_Button_Click" Content="OFF" FontWeight="Bold" Foreground="WhiteSmoke" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,5,0,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.6*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.6*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="2" Background="CadetBlue" CornerRadius="10,10,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="WhiteSmoke" Text="Current Position" />
                </Border>
                <Border Grid.Row="1" Grid.RowSpan="4" Grid.ColumnSpan="2" Background="#FF333333" CornerRadius="0,0,10,10" />
                <Viewbox Grid.Row="1" Margin="5" HorizontalAlignment="Center" Stretch="Uniform">
                    <TextBlock Margin="2" FontStyle="Normal" Foreground="WhiteSmoke" Text="Command" />
                </Viewbox>
                <Viewbox Grid.Row="2" Margin="5" HorizontalAlignment="Center" Stretch="Uniform">
                    <TextBlock Margin="2" FontStyle="Normal" Foreground="WhiteSmoke" Text="ACTUAL(Encoder)" />
                </Viewbox>
                <Border Grid.Row="1" Grid.Column="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                <Viewbox Grid.Row="1" Grid.Column="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                    <TextBlock x:Name="TbCommandPos" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" Text="0" />
                </Viewbox>
                <Border Grid.Row="2" Grid.Column="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                <Viewbox Grid.Row="2" Grid.Column="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                    <TextBlock x:Name="TbFeedBackPos" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" Text="0" />
                </Viewbox>
                <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="5,0,0,0">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock x:Name="AxisAlarm" Margin="4" Foreground="Gray" Text="ALARM" />
                        <TextBlock x:Name="AxisSAlarm" Margin="4" Foreground="Gray" Text="S_ALARM" />
                        <TextBlock x:Name="AxisMLimit" Margin="4" Foreground="Gray" Text="-LIMIT" />
                        <TextBlock x:Name="AxisPLimit" Margin="4" Foreground="Gray" Text="+LIMIT" />
                        <TextBlock x:Name="AxisOrigin" Margin="4" Foreground="Gray" Text="ORGIN" />
                        <TextBlock x:Name="AxisInpos" Margin="4" Foreground="Gray" Text="INPOS" />
                        <TextBlock x:Name="AxisSOn" Margin="4" Foreground="Gray" Text="S-ON" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="5,0,0,5">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Button Width="160" Height="30" Margin="0,0,5,0" Background="Aquamarine" Click="PosZero_Button_Click" Content="POS ZERO" />
                        <Button Width="160" Height="30" Background="Aquamarine" Click="Reset_Button_Click" Content="RESET" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="3" Margin="0,5,0,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.6*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="0.6*" />
                    <ColumnDefinition Width="0.3*" />
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="4" Background="CadetBlue" CornerRadius="10,10,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" Foreground="WhiteSmoke" Text="Action" />
                </Border>
                <Border Grid.Row="1" Grid.RowSpan="6" Grid.ColumnSpan="4" Background="#FF333333" CornerRadius="0,0,10,10" />
                <RadioButton x:Name="RbFirst"
                             Grid.Row="1"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="1 um" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <RadioButton Grid.Row="2"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="10 um" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <RadioButton Grid.Row="3"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="100 um" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <RadioButton Grid.Row="1" Grid.Column="1"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="1 mm" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <RadioButton Grid.Row="2" Grid.Column="1"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="10 mm" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <RadioButton Grid.Row="3" Grid.Column="1"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="JOG" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <Button Grid.Row="1" Grid.RowSpan="4" Grid.Column="2" Margin="5" Background="Aquamarine" Click="Home_Button_Click">
                    <Image MaxHeight="40" Source="..\..\ImagePart\Main.png" />
                </Button>
                <Button x:Name="BtShowIo"
                        Grid.Row="1" Grid.RowSpan="4" Grid.Column="3"
                        Margin="5"
                        Background="Aquamarine" Click="ShowIO_Button_Click" Content="&gt;" FontWeight="Bold" Foreground="Black" />
                <RadioButton Grid.Row="4"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="Define(mm)" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <Border Grid.Row="4" Grid.Column="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                <Viewbox Grid.Row="4" Grid.Column="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                    <TextBlock x:Name="TbDefinePos" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="0" />
                </Viewbox>
                <RadioButton Grid.Row="5"
                             Margin="10,0"
                             Checked="RadioButton_Checked" Content="ABS(mm)" FontSize="14" Foreground="WhiteSmoke"
                             Style="{StaticResource RadioButtonStyle}" />
                <Border Grid.Row="5" Grid.Column="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                <Viewbox Grid.Row="5" Grid.Column="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                    <TextBlock x:Name="TbAbsPos" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="0" />
                </Viewbox>
                <Viewbox Grid.Row="6" Margin="5" HorizontalAlignment="Center" Stretch="Uniform">
                    <TextBlock FontStyle="Normal" Foreground="WhiteSmoke" Text="Speed(mm/sec)" />
                </Viewbox>
                <Border Grid.Row="6" Grid.Column="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                <Viewbox Grid.Row="6" Grid.Column="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                    <TextBlock x:Name="TbSpeed" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="10" />
                </Viewbox>

                <ToggleButton x:Name="ToggleButton_RepeatMove"
                              Grid.Row="5" Grid.RowSpan="2" Grid.Column="2" Grid.ColumnSpan="2"
                              Margin="5"
                              Background="Aquamarine" FontWeight="Bold" Foreground="Black">
                    <StackPanel>
                        <TextBlock Text="Repeat" />
                        <TextBlock Margin="3,0" Text="Move" />
                    </StackPanel>
                </ToggleButton>
                <Popup x:Name="Popup_RepeatMove"
                       AllowsTransparency="True" HorizontalOffset="-236"
                       IsOpen="{Binding ElementName=ToggleButton_RepeatMove, Path=IsChecked}"
                       Placement="Top"
                       PlacementTarget="{Binding ElementName=ToggleButton_RepeatMove}"
                       PopupAnimation="Fade" VerticalOffset="32">
                    <Grid Width="230" Height="140" Background="#FF333333">
                        <Grid Margin="0,2,0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Row="0" Margin="5" HorizontalAlignment="Center" Stretch="Uniform">
                                <TextBlock FontStyle="Normal" Foreground="WhiteSmoke" Text="Start Position(mm)" />
                            </Viewbox>
                            <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                            <Viewbox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                                <TextBlock x:Name="TbStartPos" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="0" />
                            </Viewbox>
                            <Viewbox Grid.Row="1" Margin="5" HorizontalAlignment="Center" Stretch="Uniform">
                                <TextBlock FontStyle="Normal" Foreground="WhiteSmoke" Text="End Position(mm)" />
                            </Viewbox>
                            <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                            <Viewbox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                                <TextBlock x:Name="TbEndPos" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="10000" />
                            </Viewbox>
                            <Viewbox Grid.Row="2" Margin="9" HorizontalAlignment="Center" Stretch="Uniform">
                                <TextBlock FontStyle="Normal" Foreground="WhiteSmoke" Text="Delay Time" />
                            </Viewbox>
                            <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="1" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                            <Viewbox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="1" Margin="5" HorizontalAlignment="Right" Stretch="Uniform">
                                <TextBlock x:Name="TbDelayTime" Margin="0,0,5,1" FontStyle="Normal" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="500" />
                            </Viewbox>
                            <Button Grid.Row="3" Grid.ColumnSpan="2" Margin="3,5,3,2" Background="Aquamarine" Click="RepeatMove_Button_Click" Content="Repeat Move" />
                        </Grid>
                    </Grid>
                </Popup>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Button Margin="0,3,3,3" Background="Aquamarine" PreviewMouseLeftButtonDown="CCW_Button_MouseLeftButtonDown" PreviewMouseLeftButtonUp="CCW_Button_MouseLeftButtonUp">
                    <Image MaxHeight="40" Source="..\..\ImagePart\Left-arrow.png" />
                </Button>
                <Button Grid.Column="1" Margin="3" Background="Aquamarine" Click="Stop_Button_Click">
                    <Image MaxHeight="40" Source="..\..\ImagePart\Stop.png" />
                </Button>
                <Button Grid.Column="2" Margin="3,3,0,3" Background="Aquamarine" PreviewMouseLeftButtonDown="CW_Button_MouseLeftButtonDown" PreviewMouseLeftButtonUp="CW_Button_MouseLeftButtonUp">
                    <Image MaxHeight="40" Source="..\..\ImagePart\Right-arrow.png" />
                </Button>
            </Grid>

            <Grid Grid.Row="5">
                <Button Margin="0,3,0,3" Background="PaleVioletRed" Click="Close_Button_Click" Content="CLOSE" FontSize="20" FontWeight="Bold" />
            </Grid>
        </Grid>

        <Grid x:Name="GridShowIO" Grid.Column="1" Width="593" HorizontalAlignment="Right">
            <ContentControl x:Name="IOPanel" BorderThickness="0" />
        </Grid>
    </Grid>
</Window>