<UserControl x:Class="MachineControlBase.VisionGraphViewUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sys="clr-namespace:System;assembly=mscorlib"
             d:DesignHeight="830" d:DesignWidth="1280" IsVisibleChanged="UserControl_IsVisibleChanged"
             mc:Ignorable="d">
    <!--  Main UI 가로 7등분 분할  -->
    <Grid x:Name="Main" Margin="10" Background="#FF151515">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.06*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.3*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.7*" />
            </Grid.ColumnDefinitions>

            <Border Margin="2,2,0,2" Background="#FF7F50" CornerRadius="5,0,0,5">
                <Viewbox Margin="2" HorizontalAlignment="Stretch">
                    <DatePicker HorizontalAlignment="Center" VerticalAlignment="Top" BorderThickness="0" SelectedDate="{x:Static sys:DateTime.Now}" SelectedDateChanged="DpStart_SelectedDateChanged" />
                </Viewbox>
            </Border>

            <Border Grid.Column="1" Margin="0,2,0,2" Background="#FF7F50">
                <Viewbox HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <local:TimePicker x:Name="St_date" Grid.Row="1" Grid.Column="0" Width="200" Height="40" />
                </Viewbox>
            </Border>

            <Border Grid.Column="2" Margin="0,2,0,2" Background="#FF7F50" />
            <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Text="To" />

            <Border Grid.Column="3" Margin="0,2,0,2" Background="#FF7F50">
                <Viewbox Margin="2" HorizontalAlignment="Stretch">
                    <DatePicker HorizontalAlignment="Center" VerticalAlignment="Top" BorderThickness="0" SelectedDate="{x:Static sys:DateTime.Now}" SelectedDateChanged="DpEnd_SelectedDateChanged" />
                </Viewbox>
            </Border>

            <Border Grid.Column="4" Margin="0,2,0,2" Background="#FF7F50" CornerRadius="0,5,5,0">
                <Viewbox HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <local:TimePicker x:Name="Ed_date" Grid.Row="1" Grid.Column="2" Width="200" Height="40" />
                </Viewbox>
            </Border>

            <Button x:Name="BtSearch"
                    Grid.Column="5"
                    Background="#FF5675" Click="YSrch_btn_Click" Content="Search" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid x:Name="GdVisionMain" Background="#FF151515">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <!--  chart 표시 화면  -->
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <Border Background="#FF333333" CornerRadius="15,15,15,15">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Heavy" Foreground="AntiqueWhite" Text="Searching Result" />
                        </Border>

                        <Border Grid.Row="1" CornerRadius="0,0,10,10">
                            <ListView x:Name="LvResult" Grid.Row="1" HorizontalContentAlignment="Center" Background="#FF151515" BorderThickness="0" Foreground="AntiqueWhite">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListViewItem}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="Background" Value="Black" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="true">
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="Background" Value="Black" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.View>
                                    <GridView>
                                        <GridView.ColumnHeaderContainerStyle>
                                            <Style TargetType="{x:Type GridViewColumnHeader}">
                                                <!--  Set any properties you want to set  -->
                                                <Setter Property="Background" Value="Black" />
                                                <Setter Property="Foreground" Value="WhiteSmoke" />
                                            </Style>
                                        </GridView.ColumnHeaderContainerStyle>
                                        <GridViewColumn Width="110" DisplayMemberBinding="{Binding N_Cam}" Header="Cam Number" />
                                        <GridViewColumn Width="60" DisplayMemberBinding="{Binding Total}" Header="Total" />
                                        <GridViewColumn Width="60" DisplayMemberBinding="{Binding Good}" Header="Good" />
                                        <GridViewColumn Width="60" DisplayMemberBinding="{Binding Not_Good}" Header="Not_Good" />
                                        <GridViewColumn Width="110" DisplayMemberBinding="{Binding Function}" Header="Function" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <ContentControl x:Name="Cam_0" BorderThickness="0" />
                    <ContentControl x:Name="Cam_1" Grid.Row="1" BorderThickness="0" />
                    <ContentControl x:Name="Cam_2" Grid.Row="2" BorderThickness="0" />
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <ContentControl x:Name="Cam_3" BorderThickness="0" />
                    <ContentControl x:Name="Cam_4" Grid.Row="1" BorderThickness="0" />
                    <ContentControl x:Name="Cam_5" Grid.Row="2" BorderThickness="0" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>