<Window x:Class="MachineControlBase.TaktTimeUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="TaktTimeUI"
        Width="400" Height="220"
        Background="#FF222222" IsVisibleChanged="Window_IsVisibleChanged" ResizeMode="NoResize" Topmost="True" WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Border Margin="3" Background="Coral" CornerRadius="3,3,3,3" MouseLeftButtonDown="Border_MouseLeftButtonDown" MouseMove="Border_MouseMove">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" Text="Takt Time" />
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Margin="5" x:Name="tbTaktTimeTitle1" Foreground="White" FontWeight="Bold" FontSize="24" TextAlignment="Center" Text="Pipe"/>
                <TextBlock Margin="5" x:Name="tbTaktTime1" Foreground="White" FontSize="24" FontStyle="Oblique" TextAlignment="Center" Text="time1"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Margin="5" x:Name="tbTaktTimeTitle2" Foreground="White" FontWeight="Bold" FontSize="24" TextAlignment="Center" Text="Needle"/>
                <TextBlock Margin="5" x:Name="tbTaktTime2" Foreground="White" FontSize="24" FontStyle="Oblique" TextAlignment="Center" Text="time2"/>
            </StackPanel>
        </Grid>
        <Button Grid.Row="2" Content="Close" FontWeight="Bold" FontSize="20" Background="DarkGray" Click="BtClose_Click"/>
    </Grid>
</Window>