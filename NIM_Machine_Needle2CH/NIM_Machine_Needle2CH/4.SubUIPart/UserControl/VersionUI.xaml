<Window x:Class="MachineControlBase.CVersionUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Width="800" Height="700"
        Background="#FF222222" ResizeMode="NoResize" Topmost="True" WindowStartupLocation="CenterScreen" WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.04*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="0.08*" />
            </Grid.RowDefinitions>
            <Border Background="#FF333333" CornerRadius="5" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="Version Information" />
            </Border>
            <RichTextBox x:Name="RTbVersionInfo"
                         Grid.Row="1"
                         Margin="0,5,0,5"
                         Background="#FF111111" BorderThickness="0" FontSize="15" Foreground="WhiteSmoke" IsReadOnly="True">
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type Paragraph}">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
            <TextBlock Grid.Row="2" Margin="0,-18,0,0" HorizontalAlignment="Right" Foreground="White" Text="Icons by https://icons8.com " />
            <Button x:Name="BtClose"
                    Grid.Row="2"
                    Background="#FF444444" Click="BtClose_Click" Content="CLOSE" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" />
        </Grid>
    </Grid>
</Window>