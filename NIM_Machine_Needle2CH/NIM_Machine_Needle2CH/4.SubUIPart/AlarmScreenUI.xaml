<UserControl x:Class="MachineControlBase.AlarmScreenUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="1080" d:DesignWidth="1800" IsVisibleChanged="UserControl_IsVisibleChanged"
             mc:Ignorable="d">

    <Grid Background="#FF151515">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.5*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.12*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <Border Grid.ColumnSpan="3" Margin="0,0,0,10" Background="Crimson" CornerRadius="10,10,10,10">
                <TextBlock Grid.Column="0"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" Text="ALARM INFORMATION" />
            </Border>
            <Border Grid.Row="2" BorderBrush="#FF151515" BorderThickness="7" CornerRadius="10,10,10,10">
                <Image x:Name="ImageBox" Margin="10" />
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimationUsingKeyFrames RepeatBehavior="Forever" Storyboard.TargetProperty="BorderBrush.Color" Duration="0:0:1">
                                    <!--  LinearColorKeyFrame=서서히 색상 변경  -->
                                    <LinearColorKeyFrame Value="Red" />
                                    <LinearColorKeyFrame Value="#FF151515" />
                                </ColorAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
            <StackPanel Grid.Row="2" Grid.Column="3" Margin="10,0,0,0">
                <Border Background="CadetBlue" CornerRadius="10,10,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" Text="CODE No." />
                </Border>
                <Grid Height="100">
                    <Border Background="#FF333333" CornerRadius="0,0,10,10" />
                    <Viewbox Margin="10">
                        <TextBlock x:Name="TbCodeNo" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="WhiteSmoke" Text="00001" TextAlignment="Center" />
                    </Viewbox>
                </Grid>
                <Border Margin="0,15,0,0" Background="CadetBlue" CornerRadius="10,10,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" Text="TIME" />
                </Border>
                <Border Background="#FF333333" CornerRadius="0,0,10,10">
                    <TextBlock x:Name="TbTime" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40" Foreground="WhiteSmoke" Text="2020-04-06 10:49:04" />
                </Border>
                <Border Margin="0,15,0,0" Background="CadetBlue" CornerRadius="10,10,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" Text="ACTION" />
                </Border>
                <Border Background="#FF333333" CornerRadius="0,0,10,10">
                    <TextBlock x:Name="TbAction"
                               Width="575" Height="635"
                               Margin="5,5,5,5" HorizontalAlignment="Left"
                               FontSize="30" Foreground="WhiteSmoke" Text="Action" TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>