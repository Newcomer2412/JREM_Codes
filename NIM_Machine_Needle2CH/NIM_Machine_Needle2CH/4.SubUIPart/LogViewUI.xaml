<UserControl x:Class="MachineControlBase.LogViewUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="1080" d:DesignWidth="1800"
             mc:Ignorable="d">

    <!--  Main UI 가로 3등분 분할  -->
    <Grid Margin="10" Background="#FF151515">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="0.11*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.07*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Border Margin="0,0,10,10" Background="RoyalBlue" CornerRadius="10,10,10,10">
            <TextBlock x:Name="TBLogTitle"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" Text="Log View" />
        </Border>

        <RichTextBox x:Name="RTbLogView"
                     Grid.Row="1"
                     Margin="0,5,10,5"
                     Background="#FF111111" BorderThickness="0" FontSize="15" Foreground="WhiteSmoke" HorizontalScrollBarVisibility="Auto" IsReadOnly="True"
                     IsUndoEnabled="False" VerticalScrollBarVisibility="Auto">
            <RichTextBox.Resources>
                <Style TargetType="{x:Type Paragraph}">
                    <Setter Property="Margin" Value="0" />
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <Grid Grid.RowSpan="2" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="52" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <Border Background="CadetBlue" CornerRadius="10,10,0,0">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="WhiteSmoke" Text="Command" />
            </Border>
            <Border Grid.Row="1" Grid.RowSpan="3" Background="#FF333333" CornerRadius="0,0,10,10" />

            <Grid Grid.Row="1">
                <Button x:Name="BtFileOpen"
                        Margin="10"
                        Background="Black" BorderBrush="Aquamarine" Click="FileOpen_Button_Click" Content="File Open" FontSize="20" FontWeight="Bold"
                        Foreground="WhiteSmoke" />
            </Grid>

            <Grid Grid.Row="2">
                <Button x:Name="BtFileSave"
                        Margin="10"
                        Background="Black" BorderBrush="Aquamarine" Click="FileSave_Button_Click" Content="File Save" FontSize="20" FontWeight="Bold"
                        Foreground="WhiteSmoke" />
            </Grid>

            <Grid Grid.Row="3">
                <Button x:Name="BtReload"
                        Margin="10"
                        Background="Black" BorderBrush="Aquamarine" Click="Reload_Button_Click" Content="Reload" FontSize="20" FontWeight="Bold"
                        Foreground="WhiteSmoke" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>