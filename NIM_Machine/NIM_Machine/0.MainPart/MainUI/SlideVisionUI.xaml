<UserControl x:Class="MachineControlBase.SlideVisionUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:CognexACQFIFO="clr-namespace:Cognex.VisionPro;assembly=Cognex.VisionPro.Controls"
             xmlns:CognexImage="clr-namespace:Cognex.VisionPro.ImageFile;assembly=Cognex.VisionPro.ImageFile.Controls"
             xmlns:CognexToolBlock="clr-namespace:Cognex.VisionPro.ToolBlock;assembly=Cognex.VisionPro.ToolGroup.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="1080" d:DesignWidth="1680"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderBrush" Value="Black" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Width" Value="0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="BorderBrush" Value="Black" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>
    <TabControl x:Name="MainTap" Margin="-3,2,0,2" TabStripPlacement="Left">
        <TabItem x:Name="TabVisionMain">
            <Grid Background="Black">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <!--  Vision 표시 화면  -->
                <ContentControl x:Name="ccVision0" BorderThickness="0" />
                <ContentControl x:Name="ccVision1" Grid.Column="1" BorderThickness="0" />
                <ContentControl x:Name="ccVision2" Grid.Column="2" BorderThickness="0" />
                <ContentControl x:Name="ccVision3" Grid.Row="1" BorderThickness="0" />
                <ContentControl x:Name="ccVision4" Grid.Row="1" Grid.Column="1" BorderThickness="0" />
                <ContentControl x:Name="ccVision5" Grid.Row="1" Grid.Column="2" BorderThickness="0" />
            </Grid>
        </TabItem>

        <TabItem x:Name="TabACQFIFO">
            <Grid Background="#FF151515">
                <WindowsFormsHost Margin="5">
                    <CognexACQFIFO:CogAcqFifoEditV2 x:Name="cogAcqFifoEdit" />
                </WindowsFormsHost>
            </Grid>
        </TabItem>

        <TabItem x:Name="TabImage">
            <Grid Background="#FF151515">
                <WindowsFormsHost Margin="5">
                    <CognexImage:CogImageFileEditV2 x:Name="cogImageFileEdit" />
                </WindowsFormsHost>
            </Grid>
        </TabItem>

        <TabItem x:Name="TabToolBlock">
            <Grid Background="#FF151515">
                <WindowsFormsHost Grid.Column="1" Margin="5">
                    <CognexToolBlock:CogToolBlockEditV2 x:Name="cogToolBlockEdit" />
                </WindowsFormsHost>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>