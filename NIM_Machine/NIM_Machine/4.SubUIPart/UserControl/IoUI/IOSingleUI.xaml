<UserControl x:Class="MachineControlBase.IOSingleUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="30" d:DesignWidth="420"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.14*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Border x:Name="IOTypeBackground" Grid.Column="0" Background="CadetBlue" BorderBrush="Black" BorderThickness="0" CornerRadius="10,0,0,10" />
        <Border x:Name="IOSignalBackground"
                Grid.Column="3"
                Margin="1,0,0,0"
                Background="#FF303030" BorderBrush="Black" BorderThickness="0" CornerRadius="0,10,10,0" />

        <Viewbox Stretch="Uniform">
            <TextBlock x:Name="IOAddress" Foreground="Black" Text="10" />
        </Viewbox>
        <Button x:Name="SetIO" Grid.Column="1" Background="#00000000" Click="SetIO_Click">
            <Viewbox Stretch="Uniform">
                <TextBlock x:Name="IOName" Margin="0,0,0,1" Foreground="WhiteSmoke" Text="NONAME" />
            </Viewbox>
        </Button>
    </Grid>
</UserControl>