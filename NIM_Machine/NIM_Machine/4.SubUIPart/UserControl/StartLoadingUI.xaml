<Window x:Class="MachineControlBase.StartLoadingUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="StartLoadingUI"
        Width="500" Height="350"
        AllowsTransparency="True" Background="#FF333333" ResizeMode="NoResize" Topmost="True" WindowStartupLocation="CenterScreen" WindowStyle="None"
        mc:Ignorable="d">
    <Grid Background="Black">
        <Image Height="350" Source="..\..\ImagePart\StartImage.png" Stretch="Uniform" />
        <Viewbox Grid.Column="1" Margin="110,125,105,100" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform">
            <TextBlock x:Name="TbSystemName" FontFamily="휴먼편지체" FontSize="35" Foreground="WhiteSmoke" Text="JREM BASE" />
        </Viewbox>
    </Grid>
</Window>