<UserControl x:Class="MachineControlBase.ModelSelectUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="1080" d:DesignWidth="1800" Background="#FF151515" IsVisibleChanged="UserControl_IsVisibleChanged"
             mc:Ignorable="d">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="RoyalBlue" CornerRadius="10,10,10,10">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="45" FontWeight="Bold" Foreground="WhiteSmoke" Text="Model Setting" />
        </Border>
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.01*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="4" CornerRadius="10,10,10,10">
                <ListBox x:Name="LbModelData"
                         Margin="3,3,3,3"
                         Background="#FF222222" BorderThickness="0" FontSize="30" Foreground="WhiteSmoke" SelectionChanged="LbModelData_SelectionChanged"
                         VirtualizingStackPanel.VirtualizationMode="Recycling" />
            </Border>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.4*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="0.7*" />
                    <RowDefinition Height="0.5*" />
                </Grid.RowDefinitions>
                <Border Margin="0,0,0,10" Background="DimGray" CornerRadius="10,10,10,10">
                    <TextBlock x:Name="TbModelName"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" Text="Model Name" />
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Border Background="DarkSlateBlue" CornerRadius="10,10,0,0">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" Text="Data Copy" />
                    </Border>
                    <Border Grid.Row="1" Background="#FF333333" CornerRadius="0,0,10,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="20,20,20,0" Background="DarkSlateBlue" CornerRadius="10,10,0,0">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" MouseLeftButtonDown="TextBlock_MouseLeftButtonDown" Text="Source" />
                            </Border>
                            <Border Grid.Row="1" Margin="20,0,20,20" Background="#FF222222" CornerRadius="0,0,10,10">
                                <TextBlock x:Name="TbSourceNo"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="00" />
                            </Border>
                            <Border Grid.Column="3" Margin="20,20,20,0" Background="DarkSlateBlue" CornerRadius="10,10,0,0">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" Text="Target" />
                            </Border>
                            <Border Grid.Row="1" Grid.Column="3" Margin="20,0,20,20" Background="#FF222222" CornerRadius="0,0,10,10">
                                <TextBlock x:Name="TbTargetNo"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Text="00" />
                            </Border>

                            <Button Grid.RowSpan="2" Grid.Column="1"
                                    Margin="60,40,60,40"
                                    Background="Teal" Click="Copy_Button_Click" Content="&gt;&gt;" FontSize="50" FontWeight="Bold" Foreground="WhiteSmoke" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Border Background="DarkSlateBlue" CornerRadius="10,10,0,0">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" FontWeight="Bold" Foreground="WhiteSmoke" Text="Model Name Change" />
                    </Border>
                    <Border Grid.Row="1" Background="#FF333333" CornerRadius="0,0,10,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="0.4*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TbModelEditName"
                                     Height="50"
                                     Margin="10,10" Padding="10,0"
                                     Background="#FF222222" BorderThickness="0" FontSize="35" Foreground="WhiteSmoke" Text="TEST" />
                            <Button Grid.Column="1"
                                    Margin="10,10,10,10"
                                    Background="Teal" Click="Change_Name_Button_Click" Content="CHANGE" FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*" />
                        <ColumnDefinition Width="0.01*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="0.01*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Button Background="Teal" Click="Key_Button_Click" Content="KEY" FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" />
                    <Button Grid.Column="2"
                            Background="Teal" Click="Delete_Button_Click" Content="DELETE" FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" />
                    <Button Grid.Column="4"
                            Background="Teal" Click="Apply_Button_Click" Content="MODEL APPLY" FontSize="40" FontWeight="Bold" Foreground="WhiteSmoke" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>