                                        <Viewbox Height="25" VerticalAlignment="Center" Stretch="Uniform">
                                            <TextBlock Foreground="WhiteSmoke" Text="이온아이저" />
                                        </Viewbox>
                                        <local:IOUserUI Height="30" Margin="5" _bInput="True" _iAddress="24" />
