<Window x:Class="MachineControlBase.AlarmDataUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="AlarmDataUI"
        Width="900" Height="750"
        Background="#FF222222" ResizeMode="NoResize" Topmost="True" WindowStartupLocation="CenterScreen" WindowStyle="None"
        mc:Ignorable="d">
    <Grid>
        <Grid Margin="10,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.015*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.04*" />
                <RowDefinition Height="0.02*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <Border Grid.ColumnSpan="3" Background="#FF333333" CornerRadius="5,5,5,5" MouseLeftButtonDown="Border_MouseLeftButtonDown">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="Alarm Data Edit" />
            </Border>
            <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="2" CornerRadius="5,5,5,5">
                <ListBox x:Name="LbAlarmData"
                         Margin="3,3,3,3"
                         Background="#FF222222" BorderThickness="0" Foreground="WhiteSmoke" SelectionChanged="LbAlarmData_SelectionChanged"
                         VirtualizingStackPanel.VirtualizationMode="Recycling" />
            </Border>
            <StackPanel Grid.Row="2" Grid.Column="3">
                <Border Background="CadetBlue" CornerRadius="5,5,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" Text="CODE No." />
                </Border>
                <Border Background="#FF333333" CornerRadius="0,0,5,5">
                    <TextBlock x:Name="TbCodeNo"
                               Height="20"
                               Margin="5,5,5,5" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" Foreground="WhiteSmoke" Text="00000" />
                </Border>
                <Border Margin="0,10,0,0" Background="CadetBlue" CornerRadius="5,5,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" Text="IMAGE File Name" />
                </Border>
                <Border Background="#FF333333" CornerRadius="0,0,5,5">
                    <TextBlock x:Name="TbImagePath"
                               Height="20"
                               Margin="5,5,5,5" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="13" Foreground="WhiteSmoke" Text="Default.png" />
                </Border>
                <Border Margin="0,10,0,0" Background="CadetBlue" CornerRadius="5,5,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" Text="ACTION KOR" />
                </Border>
                <Border Background="#FF333333" CornerRadius="0,0,5,5">
                    <TextBox x:Name="TbAction_Kor"
                             Width="420" Height="100"
                             Margin="5" HorizontalAlignment="Stretch"
                             Background="#FF333333" BorderThickness="0" FontSize="13" Foreground="WhiteSmoke" TextWrapping="Wrap" />
                </Border>
                <Border Margin="0,10,0,0" Background="CadetBlue" CornerRadius="5,5,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" Text="ACTION ENG" />
                </Border>
                <Border Background="#FF333333" CornerRadius="0,0,5,5">
                    <TextBox x:Name="TbAction_Eng"
                             Width="420" Height="100"
                             Margin="5" HorizontalAlignment="Stretch"
                             Background="#FF333333" BorderThickness="0" FontSize="13" Foreground="WhiteSmoke" TextWrapping="Wrap" />
                </Border>
                <Border Margin="0,10,0,0" Background="CadetBlue" CornerRadius="5,5,0,0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" Text="ACTION CHN" />
                </Border>
                <Border Background="#FF333333" CornerRadius="0,0,5,5">
                    <TextBox x:Name="TbAction_Chn"
                             Width="420" Height="100"
                             Margin="5" HorizontalAlignment="Stretch"
                             Background="#FF333333" BorderThickness="0" FontSize="13" Foreground="WhiteSmoke" TextWrapping="Wrap" />
                </Border>
                <Grid Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="0.01*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="0.1*" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="0.1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Button x:Name="BtImageDelete"
                            Grid.Row="0" Grid.Column="2"
                            Height="54"
                            Background="#FF444444" Click="BtImageDelete_Click" FontWeight="Bold" Foreground="WhiteSmoke">
                        <TextBlock>
                            <Span Foreground="WhiteSmoke">IMAGE</Span>
                            <Span Foreground="Red">DELETE</Span>
                        </TextBlock>
                    </Button>
                    <Button x:Name="BtImageSet"
                            Grid.Row="0" Grid.Column="0"
                            Height="54"
                            Background="#FF444444" Click="BtImageSet_Click" FontWeight="Bold" Foreground="WhiteSmoke">
                        <TextBlock>
                            <Span Foreground="WhiteSmoke">IMAGE</Span>
                            <Span Foreground="Green">SET</Span>
                        </TextBlock>
                    </Button>
                    <Button x:Name="BtAlaramNoSet"
                            Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                            Height="54"
                            Background="#FF444444" Click="BtAlaramSet_Click" Content="Modify" FontWeight="Bold" Foreground="Yellow" />
                    <Button x:Name="BtClose"
                            Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                            Height="54"
                            Background="#FF444444" Click="BtClose_Click" Content="CLOSE" FontWeight="Bold" Foreground="WhiteSmoke" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>