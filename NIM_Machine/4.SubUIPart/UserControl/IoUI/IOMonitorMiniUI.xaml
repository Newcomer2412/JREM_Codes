             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Width="Auto" Height="Auto"
             d:DesignHeight="600" d:DesignWidth="600"
             mc:Ignorable="d">
    <Grid Margin="0,5,0,5" Background="#FF151515">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.01*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="0.02*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="0.01*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.7*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="1" Background="CadetBlue" CornerRadius="5,5,5,5" />
        <Grid Grid.Row="0" Grid.Column="1">
            <TextBlock Grid.Column="0"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="Input List " />
        </Grid>

        <Border Grid.Row="0" Grid.Column="3" Background="PaleVioletRed" CornerRadius="5,5,5,5" />
        <Grid Grid.Row="0" Grid.Column="3">
            <TextBlock Grid.Column="0"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="Output List " />
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.02*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BtInputUp" Grid.Column="0" Margin="0,3,0,0" Background="#FF303030" BorderThickness="0" Click="BtInputUp_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Image Height="27" Source="..\..\..\ImagePart\up-arrow.png" Stretch="Uniform" />
                    <TextBlock Grid.Column="2"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="UP" />
                </Grid>
            </Button>
            <Button x:Name="BtInputDown" Grid.Column="2" Margin="0,3,0,0" Background="#FF303030" BorderThickness="0" Click="BtInputDown_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Image Height="27" Source="..\..\..\ImagePart\down-arrow.png" Stretch="Uniform" />
                    <TextBlock Grid.Column="2"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="DOWN" />
                </Grid>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.02*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BtOutputUp" Margin="0,3,0,0" Background="#FF303030" BorderThickness="0" Click="BtOutputUp_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Image Height="27" Source="..\..\..\ImagePart\up-arrow.png" Stretch="Uniform" />
                    <TextBlock Grid.Column="2"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="UP" />
                </Grid>
            </Button>
            <Button x:Name="BtOutputDown" Grid.Column="2" Margin="0,3,0,0" Background="#FF303030" BorderThickness="0" Click="BtOutputDown_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <Image Height="27" Source="..\..\..\ImagePart\down-arrow.png" Stretch="Uniform" />
                    <TextBlock Grid.Column="2"
                               Margin="5,0,0,0" VerticalAlignment="Center"
                               FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="DOWN" />
                </Grid>
            </Button>
        </Grid>

