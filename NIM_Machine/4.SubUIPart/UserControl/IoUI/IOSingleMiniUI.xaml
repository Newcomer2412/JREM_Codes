<UserControl x:Class="MachineControlBase.IOSingleMiniUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="20" d:DesignWidth="150"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.16*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Border x:Name="IOTypeBackground" Grid.Column="0" Background="CadetBlue" BorderBrush="Black" BorderThickness="0" CornerRadius="5,0,0,5" />
        <Border x:Name="IOSignalBackground" Grid.Column="1" Background="#FF303030" BorderBrush="Black" BorderThickness="0" CornerRadius="0,5,5,0" />

        <Viewbox Grid.Column="0" Stretch="Uniform">
            <TextBlock x:Name="IOAddress" Foreground="Black" Text="10" />
        </Viewbox>
        <Button x:Name="SetIO" Grid.Column="3" Background="#00000000" Click="SetIO_Click">
            <Viewbox Stretch="Uniform">
                <TextBlock x:Name="IOName" Foreground="WhiteSmoke" Text="NONAME" />
            </Viewbox>
        </Button>
    </Grid>
</UserControl>