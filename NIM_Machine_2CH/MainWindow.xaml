                    </Button>
                    <Button Background="#FF333333" Click="btManualAxisCtl_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\MotionCtrl.png" Stretch="Uniform" />
                            <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Axis Control" />
                        </StackPanel>
                    </Button>
                    <Button Background="#FF333333" Click="All_Homming_Button_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\AllHomming.png" Stretch="Uniform" />
