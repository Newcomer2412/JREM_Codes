<Window x:Class="MachineControlBase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:CommonPartlocal="clr-namespace:MachineControlBase" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Name="TopWindow" Title="MainWindow"
        Width="1920" Height="1080"
        AllowsTransparency="False" Background="#FF151515" Closed="TopWindow_Closed" Loaded="TopWindow_Loaded" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" WindowState="Normal" WindowStyle="None"
        mc:Ignorable="d">

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>
        <ContentControl x:Name="MainPanel" BorderThickness="0" />
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="4*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="1.3*" />
                <RowDefinition Height="1.3*" />
            </Grid.RowDefinitions>
            <!--  종료 버튼  -->
            <Button Background="#FF333333" Click="Quit_Button_Click" Foreground="WhiteSmoke">
                <Image Height="50" Source="ImagePart\Shutdown.png" Stretch="Uniform" />
            </Button>
            <!--  회사 로고  -->
            <Border Grid.Row="1" Margin="2" Background="#FF333333" CornerRadius="5" />
            <Grid Grid.Row="1">
                <Image Height="40" Margin="5" MouseLeftButtonDown="Image_MouseLeftButtonDown" Source="ImagePart\JRem_Logo.png" Stretch="Uniform" />
            </Grid>
            <!--  장비 운영 정보 정의  -->
            <Border x:Name="BdTitle" Grid.Row="2" Margin="2" Background="#FF333333" CornerRadius="5" />
            <Grid Grid.Row="2" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="0.1*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="TbModelName" HorizontalAlignment="Center" FontSize="12" Foreground="WhiteSmoke" Text="Model Name" />
                <Viewbox Grid.Row="1" Margin="1">
                    <TextBlock x:Name="TbTitleStatus" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="WhiteSmoke" Text="READY" />
                </Viewbox>
                <TextBlock x:Name="TbVersion"
                           Grid.Row="2"
                           HorizontalAlignment="Center"
                           FontSize="12" Foreground="WhiteSmoke" MouseLeftButtonUp="TbVersion_MouseLeftButtonUp" Text="Ver 0.0.1" />
            </Grid>

            <!--  종료 버튼  -->
            <Button x:Name="btMainUI" Grid.Row="3" Background="#FF333333" Click="MainUI_Button_Click" Foreground="WhiteSmoke">
                <StackPanel>
                    <Image Height="50" Source="ImagePart\Main.png" Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Text="MAIN" />
                </StackPanel>
            </Button>
            <!--  Start 버튼  -->
            <Button Grid.Row="4" Background="#FF333333" Click="Start_Button_Click" Foreground="WhiteSmoke">
                <StackPanel>
                    <Image Height="50" Source="ImagePart\Start.png" Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Foreground="LightSkyBlue" Text="START" />
                </StackPanel>
            </Button>
            <!--  정지 버튼  -->
            <Button Grid.Row="5" Background="#FF333333" Click="Stop_Button_Click" Foreground="WhiteSmoke">
                <StackPanel>
                    <Image Height="50" Source="ImagePart\Stop.png" Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Foreground="Red" Text="STOP" />
                </StackPanel>
            </Button>
            <!--  리셋 버튼  -->
            <Button Grid.Row="6" Background="#FF333333" Click="Reset_Button_Click" Foreground="WhiteSmoke">
                <StackPanel>
                    <Image Height="50" Source="ImagePart\Reset.png" Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Text="RESET" />
                </StackPanel>
            </Button>
            <!--  유저 권한 버튼  -->
            <Button x:Name="BtUserLevel"
                    Grid.Row="7" Grid.Column="5"
                    Background="#FF333333" Click="BtUserLevel_Click" FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center" Text="USER LEVEL" />
                    <TextBlock x:Name="TbUserLevel" HorizontalAlignment="Center" Foreground="LightSkyBlue" Text="OPERATOR" />
                </StackPanel>
            </Button>
            <Popup x:Name="Popup_UserLevel"
                   AllowsTransparency="True" HorizontalOffset="0" Placement="Top"
                   PlacementTarget="{Binding ElementName=BtUserLevel}"
                   PopupAnimation="Fade" VerticalOffset="0">
                <Grid Width="120" Height="320" Background="#FF333333">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <ToggleButton x:Name="TbOperator"
                                      Background="CornflowerBlue" Click="ToggleButton_Click" Content="OPERATOR" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" />
                        <ToggleButton Name="TbEngineer"
                                      Grid.Row="1"
                                      Background="CornflowerBlue" Click="ToggleButton_Click" Content="ENGINEER" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" />
                        <ToggleButton Name="TbAdministrator"
                                      Grid.Row="2"
                                      Background="CornflowerBlue" Click="ToggleButton_Click" Content="ADMINISTRATOR" FontSize="13" FontWeight="Bold" Foreground="WhiteSmoke" />
                        <Border Grid.Row="3" Margin="5" Background="Black" CornerRadius="5,5,5,5" />
                        <PasswordBox x:Name="PbPassword"
                                     Grid.Row="3"
                                     Margin="10" HorizontalAlignment="Stretch" VerticalAlignment="Center" HorizontalContentAlignment="Center"
                                     Background="Black" BorderThickness="0" FontSize="10" FontStyle="Normal" Foreground="WhiteSmoke" KeyDown="PbPassword_KeyDown" />
                        <Button Grid.Row="4" Grid.ColumnSpan="2" Margin="1" Background="Aquamarine" Click="Password_Change_Button_Click" Content="Password Change" />
                        <Button x:Name="BtLogin"
                                Grid.Row="5" Grid.ColumnSpan="2"
                                Margin="1"
                                Background="Aquamarine" Click="Login_Button_Click" Content="Login" />
                    </Grid>
                </Grid>
            </Popup>
            <!--  장비 특정 상태 정보 정의  -->
            <Border Grid.Row="8" Background="#FF333333" CornerRadius="5" />
            <Grid Grid.Row="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border_MainPowerFlag" Margin="2" Background="Gray" CornerRadius="5">
                    <Viewbox Stretch="Uniform">
                        <TextBlock Margin="5" Foreground="WhiteSmoke" Text="MAIN POWER" />
                    </Viewbox>
                </Border>
                <Border x:Name="Border_MainAirFlag" Grid.Column="1" Margin="2" Background="Gray" CornerRadius="5">
                    <Viewbox Stretch="Uniform">
                        <TextBlock Margin="10" Foreground="WhiteSmoke" Text="AIR INPUT" />
                    </Viewbox>
                </Border>
                <Border x:Name="Border_DoorCheckFlag" Grid.Row="1" Margin="2" Background="Gray" CornerRadius="5" PreviewMouseDown="Border_DoorCheckFlag_PreviewMouseDown">
                    <Viewbox Stretch="Uniform">
                        <TextBlock Margin="5" Foreground="WhiteSmoke" Text="DOOR CHECK" />
                    </Viewbox>
                </Border>
                <Popup x:Name="Popup_DoorCheck" AllowsTransparency="True" Placement="Left" PlacementTarget="{Binding ElementName=Border_DoorCheckFlag}" PopupAnimation="Scroll" VerticalOffset="-265">
                    <Grid Width="638" Height="382" Background="#AA000000">
                        <Border BorderBrush="WhiteSmoke" BorderThickness="2" CornerRadius="10" />
                        <Canvas Background="Transparent">
                            <Image Canvas.Left="86" Canvas.Top="26"
                                   Width="480" Height="338"
                                   Opacity="0.5" Source="ImagePart\All_Layout.png" Stretch="Uniform" />
                            <Rectangle x:Name="Rt_88_CLOSE_CHECK_DOOR_FRONT_LEFT"
                                       Canvas.Left="182" Canvas.Top="80"
                                       Width="94" Height="8"
                                       Fill="Transparent" Stroke="Red" StrokeDashArray="1" StrokeThickness="3" Visibility="Hidden">
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Rt_88_CLOSE_CHECK_DOOR_FRONT_LEFT" Storyboard.TargetProperty="StrokeThickness" To="4" Duration="0:0:0.25" />
                                                <DoubleAnimation RepeatBehavior="Forever" Storyboard.TargetName="Rt_88_CLOSE_CHECK_DOOR_FRONT_LEFT" Storyboard.TargetProperty="StrokeDashOffset" From="1000" To="0" Duration="0:3:0" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="Rt_18_CLOSE_CHECK_DOOR_FRONT_CENTER_LEFT"
                                       Canvas.Left="299" Canvas.Top="89"
                                       Width="45" Height="8"
                                       Fill="Transparent" RenderTransformOrigin="0.5,0.5" Stroke="Red" StrokeDashArray="1" StrokeThickness="3" Visibility="Hidden">
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Rt_18_CLOSE_CHECK_DOOR_FRONT_CENTER_LEFT" Storyboard.TargetProperty="StrokeThickness" To="4" Duration="0:0:0.25" />
                                                <DoubleAnimation RepeatBehavior="Forever" Storyboard.TargetName="Rt_18_CLOSE_CHECK_DOOR_FRONT_CENTER_LEFT" Storyboard.TargetProperty="StrokeDashOffset" From="1000" To="0" Duration="0:3:0" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="Rt_16_CLOSE_CHECK_DOOR_FRONT_CENTER_RIGHT"
                                       Canvas.Left="346" Canvas.Top="89"
                                       Width="87" Height="8"
                                       Fill="Transparent" Stroke="Red" StrokeDashArray="1" StrokeThickness="3" Visibility="Hidden">
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Rt_16_CLOSE_CHECK_DOOR_FRONT_CENTER_RIGHT" Storyboard.TargetProperty="StrokeThickness" To="4" Duration="0:0:0.25" />
                                                <DoubleAnimation RepeatBehavior="Forever" Storyboard.TargetName="Rt_16_CLOSE_CHECK_DOOR_FRONT_CENTER_RIGHT" Storyboard.TargetProperty="StrokeDashOffset" From="1000" To="0" Duration="0:3:0" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="Rt_14_CLOSE_CHECK_DOOR_FRONT_RIGHT"
                                       Canvas.Left="454" Canvas.Top="83"
                                       Width="71" Height="8"
                                       Fill="Transparent" Stroke="Red" StrokeDashArray="1" StrokeThickness="3" Visibility="Hidden">
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Rt_14_CLOSE_CHECK_DOOR_FRONT_RIGHT" Storyboard.TargetProperty="StrokeThickness" To="4" Duration="0:0:0.25" />
                                                <DoubleAnimation RepeatBehavior="Forever" Storyboard.TargetName="Rt_14_CLOSE_CHECK_DOOR_FRONT_RIGHT" Storyboard.TargetProperty="StrokeDashOffset" From="1000" To="0" Duration="0:3:0" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="Rt_20_CLOSE_CHECK_DOOR_REAR_LEFT"
                                       Canvas.Left="312" Canvas.Top="49"
                                       Width="119" Height="8"
                                       Fill="Transparent" RenderTransformOrigin="0.5,0.5" Stroke="Red" StrokeDashArray="1" StrokeThickness="3" Visibility="Hidden">
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Rt_20_CLOSE_CHECK_DOOR_REAR_LEFT" Storyboard.TargetProperty="StrokeThickness" To="4" Duration="0:0:0.25" />
                                                <DoubleAnimation RepeatBehavior="Forever" Storyboard.TargetName="Rt_20_CLOSE_CHECK_DOOR_REAR_LEFT" Storyboard.TargetProperty="StrokeDashOffset" From="1000" To="0" Duration="0:3:0" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                            <Rectangle x:Name="Rt_22_CLOSE_CHECK_DOOR_REAR_RIGHT"
                                       Canvas.Left="434" Canvas.Top="49"
                                       Width="115" Height="8"
                                       Fill="Transparent" Stroke="Red" StrokeDashArray="1" StrokeThickness="3" Visibility="Hidden">
                                <Rectangle.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Rt_22_CLOSE_CHECK_DOOR_REAR_RIGHT" Storyboard.TargetProperty="StrokeThickness" To="4" Duration="0:0:0.25" />
                                                <DoubleAnimation RepeatBehavior="Forever" Storyboard.TargetName="Rt_22_CLOSE_CHECK_DOOR_REAR_RIGHT" Storyboard.TargetProperty="StrokeDashOffset" From="1000" To="0" Duration="0:3:0" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Rectangle.Triggers>
                            </Rectangle>
                        </Canvas>
                    </Grid>
                </Popup>
                <Border x:Name="Border_ConnectCheckFlag"
                        Grid.Row="1" Grid.Column="1"
                        Margin="2"
                        Background="Gray" CornerRadius="5" PreviewMouseDown="Border_ConnectCheckFlag_PreviewMouseDown">
                    <Viewbox Stretch="Uniform">
                        <TextBlock Margin="5" Foreground="WhiteSmoke" Text="EX CONNCET" />
                    </Viewbox>
                </Border>
                <Popup x:Name="Popup_ConnectCheck"
                       AllowsTransparency="True" HorizontalOffset="0" Placement="Left"
                       PlacementTarget="{Binding ElementName=Popup_ConnectCheck}"
                       PopupAnimation="Scroll" VerticalOffset="-590">
                    <Grid Width="370" Height="910" Background="#AA000000">
                        <Border BorderBrush="WhiteSmoke" BorderThickness="2" CornerRadius="10" />
                        <StackPanel Margin="10">
                            <TextBlock Margin="5" FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="Vision Light (232)" />
                            <Image x:Name="ImgVisionLightConnect"
                                   Height="40"
                                   Margin="5" HorizontalAlignment="Left"
                                   Opacity="0.3" Source="ImagePart\Close.png" Stretch="Uniform" />
                            <Line Height="1"
                                  Margin="5"
                                  Stroke="Yellow" X1="0" X2="405" Y1="0" Y2="0" />
                            <TextBlock Margin="5" FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="Altis UV (232)" />
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="ImgAltisUV"
                                       Height="40"
                                       Margin="5,5,5,5" HorizontalAlignment="Left"
                                       Opacity="0.3" Source="ImagePart\Close.png" Stretch="Uniform" />
                            </StackPanel>

                            <Line Height="1"
                                  Margin="5"
                                  Stroke="Yellow" X1="0" X2="405" Y1="0" Y2="0" />
                            <TextBlock Margin="5" FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="AIM Feeder (TCP/IP)" />
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="ImgAIMFeeder"
                                       Height="40"
                                       Margin="5,5,5,5" HorizontalAlignment="Left"
                                       Opacity="0.3" Source="ImagePart\Close.png" Stretch="Uniform" />
                            </StackPanel>
                            <Line Height="1"
                                  Margin="5"
                                  Stroke="Yellow" X1="0" X2="405" Y1="0" Y2="0" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="5,0,0,0" FontSize="12" FontWeight="Bold" Foreground="Yellow" Text="이미지 클릭 : 재섭속" />
                                <TextBlock Margin="35,0,0,0" FontSize="12" FontWeight="Bold" Foreground="Red" Text="RED 폰트 : 알람 상태" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Popup>
            </Grid>
            <!--  장비 시간 정보 정의  -->
            <Border Grid.Row="9" Margin="2" Background="#FF333333" CornerRadius="5" />
            <Grid Grid.Row="9" Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <!--  TextBlock 설정 통합 정의  -->
                <Grid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="WhiteSmoke" />
                        <Setter Property="HorizontalAlignment" Value="Center" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="FontSize" Value="11" />
                    </Style>
                </Grid.Resources>
                <TextBlock Grid.Column="0" Text="RUN TIME" />
                <TextBlock x:Name="TbRunnigTime" Grid.Column="1" Text="00:00:00" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="STOP TIME" />
                <TextBlock x:Name="TbStopTime" Grid.Row="1" Grid.Column="1" Text="00:00:00" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="ERROR TIME" />
                <TextBlock x:Name="TbErrorTime" Grid.Row="2" Grid.Column="1" Text="00:00:00" />
            </Grid>
            <!--  로그 및 기타 정보 버튼  -->
            <Button x:Name="btInfo" Grid.Row="10" Background="#FF333333" Click="InfoButton_Click" Foreground="WhiteSmoke">
                <StackPanel>
                    <Image Height="50" Source="ImagePart\List.png" Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center" Text="INFORMATION" />
                </StackPanel>
            </Button>
            <Popup x:Name="Popup_Info" AllowsTransparency="True" Placement="Top" PlacementTarget="{Binding ElementName=btInfo}" PopupAnimation="Fade">
                <StackPanel Width="120" Height="920" Background="Black">
                    <ToggleButton x:Name="LogViewPopupButton" Padding="10,10" HorizontalContentAlignment="Left" Background="#FF333333" BorderThickness="0">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\LogList.png" Stretch="Uniform" />
                            <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Log View" />
                        </StackPanel>
                    </ToggleButton>
                    <!--  Manual 버튼 클릭 시 팝업 기능 정의  -->
                    <Popup VerticalAlignment="Top" AllowsTransparency="True" IsOpen="{Binding ElementName=LogViewPopupButton, Path=IsChecked}" Placement="Left" PopupAnimation="Fade">
                        <!--  팝업 버튼 기능 정의  -->
                        <StackPanel Width="120">
                            <Button Background="#FF333333" Click="ProgramLogView_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Program Log" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="SeqMainLogView_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Seq Main Log" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="Front_MPC_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Front MPC" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="RearMPC_Left_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Rear MPC Left" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="RearMPC_Right_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Rear MPC Right" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="HolderSnR_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Holder S n R" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="Hopper_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Hopper" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="PipePnP_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Pipe P n P" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="NeedlePnP_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Needle P n P" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="Transfer_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Transfer" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="PipeMount_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Pipe Mount" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="NeedleMount_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Needle Mount" />
                                </StackPanel>
                            </Button>
                            <Button Background="#FF333333" Click="DispMount_View_Button_Click">
                                <StackPanel Margin="5">
                                    <Image Height="40" Source="ImagePart\Log.png" Stretch="Uniform" />
                                    <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Dispensing" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Popup>

                    <Button Background="#FF333333" Click="Graph_Button_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\ProductGraph.png" Stretch="Uniform" />
                            <TextBlock FontSize="13" Foreground="WhiteSmoke" Text="PRODUCT GRAPH" />
                        </StackPanel>
                    </Button>
                    <Button Background="#FF333333" Click="VisionGraph_Button_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\ProductGraph.png" Stretch="Uniform" />
                            <TextBlock FontSize="13" Foreground="WhiteSmoke" Text="VISION GRAPH" />
                        </StackPanel>
                    </Button>
                    <Button Background="#FF333333" Click="ErrorView_Button_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\ErrorGraph.png" Stretch="Uniform" />
                            <TextBlock FontSize="13" Foreground="WhiteSmoke" Text="ERROR GRAPH" />
                        </StackPanel>
                    </Button>
                    <Button Background="#FF333333" Click="TaktTime_Button_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\TaktTime.png" Stretch="Uniform" />
                            <TextBlock FontSize="13" Foreground="WhiteSmoke" Text="Takt Time" />
