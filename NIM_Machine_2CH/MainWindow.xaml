                        </StackPanel>
                    </Button>
                    <Button Background="#FF333333" Click="Option_Button_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\Option.png" Stretch="Uniform" />
                            <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Option" />
