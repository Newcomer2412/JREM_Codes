                    </Button>
                    <Button Background="#FF333333" Click="btViewMotionParam_Click">
                        <StackPanel Margin="5">
                            <Image Height="40" Source="ImagePart\AxisParam.png" Stretch="Uniform" />
                            <TextBlock FontSize="14" Foreground="WhiteSmoke" Text="Axis Parameter" />
