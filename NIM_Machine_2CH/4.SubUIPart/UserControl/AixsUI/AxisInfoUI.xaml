<UserControl x:Class="MachineControlBase.AxisInfoUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="20" d:DesignWidth="420"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="0.6*" />
            <ColumnDefinition Width="0.6*" />
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="6" Background="Black" BorderBrush="Black" BorderThickness="0" CornerRadius="10" />
        <Viewbox Stretch="Uniform">
            <TextBlock Margin="3,3,3,3" Foreground="WhiteSmoke" Text="TYPE" />
        </Viewbox>
        <Viewbox Grid.Column="1" Stretch="Uniform">
            <TextBlock Margin="3,3,3,3" Foreground="WhiteSmoke" Text="NAME" />
        </Viewbox>
        <Viewbox Grid.Column="2" Stretch="Uniform">
            <TextBlock Margin="3,3,3,3" Foreground="WhiteSmoke" Text="VALUE" />
        </Viewbox>
        <Viewbox Grid.Column="3" Stretch="Uniform">
            <TextBlock Margin="3,3,3,3" Foreground="WhiteSmoke" Text="UNIT" />
        </Viewbox>
        <Viewbox Grid.Column="4" Stretch="Uniform">
            <TextBlock Margin="3,3,3,3" Foreground="WhiteSmoke" Text="SPEED(%)" />
        </Viewbox>
    </Grid>
</UserControl>