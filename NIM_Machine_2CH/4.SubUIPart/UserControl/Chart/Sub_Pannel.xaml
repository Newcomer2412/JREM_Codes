<UserControl x:Class="MachineControlBase.Sub_Pannel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="530" d:DesignWidth="640"
             mc:Ignorable="d">
    <Grid Background="#FF151515">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>
            <Border Margin="0,0,1,1" Background="#FF333333" BorderThickness="0" CornerRadius="15">
                <Grid>
                    <TextBlock x:Name="TbTitle"
                               Grid.Column="2"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="15" FontWeight="Bold" Foreground="WhiteSmoke" Text="No Name" />
                </Grid>
            </Border>

            <Grid x:Name="GdMainView" Grid.Row="1">
                <local:Pie x:Name="Pie" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>