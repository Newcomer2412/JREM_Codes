<UserControl x:Class="MachineControlBase.IOActuatorUI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MachineControlBase"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="30" d:DesignWidth="200"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="0.3*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Row="0" Grid.ColumnSpan="3" Background="Black" BorderBrush="Black" BorderThickness="0" CornerRadius="5,5,0,0" />
            <Viewbox Grid.Column="0" Stretch="Uniform">
                <TextBlock Margin="0,0,0,1" FontWeight="Bold" Foreground="Magenta" Text="ACT" />
            </Viewbox>
            <Viewbox Grid.Column="1" Stretch="Uniform">
                <TextBlock x:Name="ActuatorName" Margin="0,0,0,1" Foreground="WhiteSmoke" Text="No Name" />
            </Viewbox>
            <Viewbox Grid.Column="2" Stretch="Uniform">
                <TextBlock x:Name="ActuatorTime" Margin="0,0,0,1" Foreground="WhiteSmoke" Text="0" />
            </Viewbox>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="ACTBorder1" Grid.Column="0" Background="Gray" BorderBrush="Black" BorderThickness="0" CornerRadius="0,0,0,5" />
            <Border x:Name="ACTBorder2" Grid.Column="1" Background="Gray" BorderBrush="Black" BorderThickness="0" />
            <Border x:Name="ACTBorder3" Grid.Column="2" Background="CadetBlue" BorderBrush="Black" BorderThickness="0" CornerRadius="0,0,5,0" />
            <Button x:Name="btFWD" Grid.Column="0" Background="#00000000" Click="btFWD_Click">
                <Viewbox Stretch="Uniform">
                    <TextBlock x:Name="TbFWD" Margin="0,0,0,1" FontWeight="Bold" Foreground="Black" Text="FWD" />
                </Viewbox>
            </Button>
            <Button x:Name="btBWD" Grid.Column="1" Background="#00000000" Click="btBWD_Click">
                <Viewbox Stretch="Uniform">
                    <TextBlock x:Name="TbBWD" Margin="0,0,0,1" FontWeight="Bold" Foreground="Black" Text="BWD" />
                </Viewbox>
            </Button>
            <Button x:Name="btRepeat" Grid.Column="2" Background="#00000000" Click="btRepeat_Click">
                <Viewbox Stretch="Uniform">
                    <TextBlock Margin="0,0,0,1" FontWeight="Bold" Foreground="Black" Text="REPEAT" />
                </Viewbox>
            </Button>
        </Grid>
    </Grid>
</UserControl>