                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="tbHolderNeedleOffset_X"
                                           Width="100"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="30" Foreground="White" PreviewMouseDown="Value_Changer" Text="0" TextAlignment="Center" />
                                <TextBlock x:Name="tbHolderNeedleOffset_Y"
                                           Grid.Column="1"
                                           Width="100"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="30" Foreground="White" PreviewMouseDown="Value_Changer" Text="0" TextAlignment="Center" />
                            </Grid>
                            <local:UserNumInputUI x:Name="UICAM0_NeedleMount_X_CameraCal" Height="25" Margin="10" _strName="니들 마운트 X 카메라 Cal" />
                            <local:UserNumInputUI x:Name="UICAM0_NeedleMount_Y_CameraCal" Height="25" Margin="10" _strName="니들 마운트 Y 카메라 Cal" />
                            <local:UserNumInputUI x:Name="UICAM4_NeedleMountCal_X_Limit" Height="25" Margin="10" _strName="니들 마운트 캘리브레이션 X Limit" />
                            <local:UserNumInputUI x:Name="UICAM4_NeedleMountCal_Y_Limit" Height="25" Margin="10" _strName="니들 마운트 캘리브레이션 Y Limit" />
                        </StackPanel>
                    </Grid>
                    <Grid Canvas.Left="1090" Canvas.Top="550" Width="533" Height="200">
                        <Border Grid.RowSpan="2" Background="#19FFFFFF" CornerRadius="10,10,10,10" />
                        <StackPanel>
                            <TextBlock Margin="10" FontSize="20" Foreground="WhiteSmoke" Text="6번 카메라" />
                            <local:UserNumInputUI x:Name="UICAM5_Disp_X_CameraCal" Height="25" Margin="10" _strName="디스펜서 캘리브레이션 X Limit" />
                            <local:UserNumInputUI x:Name="UICAM5_Disp_Y_CameraCal" Height="25" Margin="10" _strName="디스펜서 캘리브레이션 Y Limit" />
                        </StackPanel>
                    </Grid>
                </Canvas>
            </TabItem>
            <TabItem Width="170" Header="기타 설정">
                <Canvas Background="Black">
                    <Grid Canvas.Left="10" Canvas.Top="10" Width="533">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <Border Grid.RowSpan="3" Background="#19FFFFFF" CornerRadius="10,10,10,10" />
                        <ToggleButton x:Name="TbLightSerialUse"
                                      Margin="20"
                                      Content="조명 Serial 통신을 사용합니다." FontSize="20" FontWeight="Normal" Foreground="GreenYellow" IsChecked="False"
                                      Style="{DynamicResource ToggleSwitchTopStyle}" />
                        <TextBlock Margin="95,0,0,23" VerticalAlignment="Bottom" FontSize="20" FontWeight="Normal" Foreground="WhiteSmoke">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Off" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=TbLightSerialUse, Path=IsChecked}" Value="True">
                                            <Setter Property="Text" Value="On" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ElementName=TbLightSerialUse, Path=IsEnabled}" Value="false">
                                            <Setter Property="Opacity" Value="0.2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <local:UserStrInputUI x:Name="UILightSerialComPort" Grid.Row="1" Height="25" Margin="10,10,10,20" _strData="COM1" _strName="Light Com Port Number" />
                    </Grid>
                    <Grid Canvas.Left="10" Canvas.Top="179" Width="533" Height="100">
                        <Border Grid.RowSpan="3" Background="#19FFFFFF" CornerRadius="10" />
                        <StackPanel Margin="10">
                            <TextBlock Margin="10,5,0,5" VerticalAlignment="Bottom" FontSize="18" FontWeight="Normal" Foreground="GreenYellow" Text="UV 컨트롤러 Serial 통신 포트" />
                            <local:UserStrInputUI x:Name="UIUV_CtlComPort" Height="25" Margin="10,10,10,20" _strData="COM2" _strName="UV Controller Com Port" />
                        </StackPanel>
                    </Grid>
                    <Grid Canvas.Left="1086" Canvas.Top="10" Width="533" Height="100">
                        <Border Grid.RowSpan="3" Background="#19FFFFFF" CornerRadius="10" />
                        <StackPanel Margin="10">
                            <TextBlock Margin="10,5,0,5" VerticalAlignment="Bottom" FontSize="18" FontWeight="Normal" Foreground="GreenYellow" Text="AIM 피더 IP Address" />
