                        </StackPanel>
                    </Grid>
                    <Grid Canvas.Left="1300" Canvas.Top="500" Width="200" Height="100">
                        <!--<Button Background="#FF333333" Click="Quit_Button_Click" Foreground="WhiteSmoke">
                            <Image Height="50" Source="ImagePart\Shutdown.png" Stretch="Uniform" />
                        </Button>-->
                    </Grid>
                </Canvas>
            </TabItem>
        </TabControl>
        <Button x:Name="BTSave"
                Width="170" Height="70"
                Margin="2,0,0,5" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="OrangeRed" Click="BTSave_Click" Content="저장" FontSize="20" Foreground="WhiteSmoke" />
    </Grid>
</UserControl>